# =============================================================================
# OmniSupply environment variables
# Copy to .env for local dev (.env is gitignored). On Railway, set these in the
# service's Variables tab — do NOT put real values in this file.
# =============================================================================

# --- Required ---------------------------------------------------------------

# OpenAI — every agent + the supervisor calls this. Default model is gpt-4o-mini.
OPENAI_API_KEY=

# PostgreSQL connection string. database.py rejects anything that doesn't start
# with "postgresql://". On Railway: add the Postgres plugin to your project and
# Railway will inject this variable automatically — leave it blank here.
# Local format: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# --- Optional but recommended ----------------------------------------------

# OpenAI model override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Comet / Opik observability. Without these, agents still run but no LLM
# traces are recorded. Free tier at https://www.comet.com/signup.
COMET_API_KEY=
COMET_WORKSPACE=
OPIK_PROJECT_NAME=omnisupply

# --- Optional features ------------------------------------------------------

# Redis — only needed if you run the Celery scheduler (daily reports, periodic
# risk checks). The on-demand Streamlit/API path works without it. On Railway:
# add the Redis plugin and it's injected as REDIS_URL.
REDIS_URL=redis://localhost:6379/0

# SMTP — only needed if the email agent sends real emails. Without these the
# agent runs but only drafts message content.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=omnisupply@company.com
